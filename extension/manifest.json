{
  "manifest_version": 3,
  "name": "InfiniBot for Infinite Craft",
  "version": "1.0",
  "description": "An automated crafting bot for neal.fun/infinite-craft",
  "content_scripts": [
    {
      "matches": ["*://neal.fun/infinite-craft/*", "*://www.neal.fun/infinite-craft/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ]
}